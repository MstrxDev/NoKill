<Window x:Class="NoKill.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NoKill.App"
        Title="NoKill — Rescue Dashboard" Height="640" Width="960"
        d:DataContext="{d:DesignInstance Type=local:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <DockPanel Margin="8">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="Refresh" Padding="16,4"
                    Command="{Binding RefreshCommand}"/>
            <CheckBox DockPanel.Dock="Right" Content="Auto-preserve on freeze (watchdog)"
                      IsChecked="{Binding WatchdogEnabled}" VerticalAlignment="Center"
                      Margin="0,0,16,0"/>
            <TextBlock Text="Read-only scan, refreshed every 3 s"
                       VerticalAlignment="Center" FontWeight="Bold"/>
        </DockPanel>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding StatusText}"/>
        </StatusBar>

        <TabControl>
            <TabItem Header="Live monitor">
        <Grid Margin="0,6,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" ItemsSource="{Binding Windows}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130"/>
                    <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="170"/>
                    <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="70"/>
                    <DataGridTextColumn Header="Window title" Binding="{Binding Title}" Width="*"/>
                    <DataGridTemplateColumn Header="Actions" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Preserve" Padding="8,2" Margin="2"
                                            Command="{Binding DataContext.PreserveCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Diagnose" Padding="8,2" Margin="2"
                                            Command="{Binding DataContext.DiagnoseCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="NotResponding">
                                <Setter Property="Background" Value="#FFD6D6"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="LikelyHung">
                                <Setter Property="Background" Value="#FFEFD6"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Unknown">
                                <Setter Property="Foreground" Value="Gray"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <TextBlock Grid.Row="1" Text="Suspected modal blockers" FontWeight="Bold" Margin="0,10,0,4"/>

            <DataGrid Grid.Row="2" ItemsSource="{Binding Blockers}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Blocked window" Binding="{Binding BlockedWindowTitle}" Width="220"/>
                    <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="120"/>
                    <DataGridTextColumn Header="Blocking dialog" Binding="{Binding BlockerTitle}" Width="150"/>
                    <DataGridCheckBoxColumn Header="Hidden?" Binding="{Binding IsHiddenBlocker, Mode=OneWay}" Width="70"/>
                    <DataGridTextColumn Header="Dialog says" Binding="{Binding BlockerContent}" Width="*"/>
                    <DataGridTemplateColumn Header="Action" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Reveal" Padding="8,2" Margin="2"
                                        Command="{Binding DataContext.RevealBlockerCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHiddenBlocker}" Value="True">
                                <Setter Property="Background" Value="#FFF2C8"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Grid>
            </TabItem>

            <TabItem Header="Freeze history">
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                        <Button DockPanel.Dock="Right" Content="Refresh history" Padding="12,4"
                                Command="{Binding RefreshHistoryCommand}"/>
                        <TextBlock Text="Recorded freeze incidents (newest first)"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding HistoryRecords}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="When"
                                                Binding="{Binding StartedAt, StringFormat='MM-dd HH:mm:ss'}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="150"/>
                            <DataGridTextColumn Header="Trigger" Binding="{Binding Trigger}" Width="80"/>
                            <DataGridTextColumn Header="Duration"
                                                Binding="{Binding Duration.TotalSeconds, StringFormat='{}{0:F0} s'}"
                                                Width="80"/>
                            <DataGridTextColumn Header="Insight" Binding="{Binding Insight}" Width="*"/>
                            <DataGridTemplateColumn Header="Evidence" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Open entry" Padding="8,2" Margin="2"
                                                Command="{Binding DataContext.OpenVaultEntryCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Trigger}" Value="watchdog">
                                        <Setter Property="Background" Value="#EAF2FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>

                    <DockPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBlock DockPanel.Dock="Left" Text="Top offenders:  "
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <ItemsControl ItemsSource="{Binding TopOffenders}" VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F0F0F0" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock>
                                            <Run Text="{Binding ProcessName, Mode=OneWay}" FontWeight="Bold"/>
                                            <Run Text="{Binding IncidentCount, Mode=OneWay, StringFormat='×{0}'}"/>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
